# Server
NODE_ENV=development
PORT=4000

# Postgres connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:7576524@localhost:5432/meetwise?schema=public"

# CORS — the frontend's origin (Vite dev server by default)
CLIENT_ORIGIN="http://localhost:5173"

# JWT
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_REFRESH_EXPIRES_IN="30d"

# Signs the httpOnly cookie that carries the refresh token
COOKIE_SECRET="replace-with-another-long-random-string"

# AI foundation (see backend/src/modules/ai) — optional. Leave AI_ENABLED
# unset/false to run the app with no AI configuration at all, exactly as
# before this was added. Set AI_ENABLED=true and provide a real
# GEMINI_API_KEY to turn on GET /api/v1/ai/health reporting "configured"
# and (non-production only) POST /api/v1/ai/test.
AI_ENABLED=false
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
